{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "apps/server/src/**/*.ts",
    "apps/server/tests/**/*.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/e2e/**/*.ts",
    "apps/web/*.config.ts",
    "packages/shared/src/**/*.ts"
  ]
}
