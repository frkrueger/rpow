VITE_API_BASE_URL=http://localhost:8080
# Cloudflare Turnstile site key. Optional in dev — when unset, the Login
# page renders without the human-verification widget and the server skips
# the gate (TURNSTILE_SECRET also unset). Set both in production.
VITE_TURNSTILE_SITE_KEY=
# Used by /usdc/deposit. Helius mainnet endpoint with API key.
VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
